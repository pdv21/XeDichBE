# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# Database - MySQL
DB_HOST=127.0.0.1
DB_PORT=3636
DB_NAME=xedich_db
DB_USER=root
DB_PASSWORD=rootpassword

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Mailer
RESEND_API_KEY=your_resend_api_key
MAIL_FROM=no-reply@xedich.space

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# LiteAPI (hotel)
LITEAPI_BASE_URL=https://api.liteapi.travel/v3.0
LITEAPI_API_KEY=your_liteapi_api_key
HOTEL_SYNC_MAX_PER_CITY=1000

# Ignav (flight)
IGNAV_API_KEY=your_ignav_api_key

# OpenTripMap (địa điểm tham quan / ăn uống — crawl vào bảng places)
OPENTRIPMAP_BASE_URL=https://api.opentripmap.com/0.1/en
OPENTRIPMAP_API_KEY=your_opentripmap_api_key

# LLM — Google Gemini (free tier), dùng cho bước AI Personalization của lịch trình
GEMINI_KEY=your_gemini_api_key
LLM_MODEL=gemini-flash-latest

# Google Maps
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Cache
PRICE_CACHE_TTL=21600

# Budget — fallback khi places.avg_cost chưa enrich hoặc chưa có lịch trình (VND), optional.
# Chi phí ăn uống/vé tham quan thật lấy từ places.avg_cost (enrich bởi Gemini,
# xem place.enrich.job.js#enrichCostsFromGemini); di chuyển tính theo khoảng cách
# route thật, xem BUDGET_TRANSPORT_* bên dưới.
BUDGET_MEAL_COST_VND=100000
BUDGET_ATTRACTION_FEE_VND=50000
BUDGET_TRANSPORT_VND_PER_DAY=250000
# Cước di chuyển nội thành theo khoảng cách thật (mô hình Grab: phí mở cửa + phí/km).
# Xe máy khi nhóm <=2 người (mỗi người 1 xe), ô tô 4 chỗ khi nhóm lớn hơn.
BUDGET_TRANSPORT_BIKE_BASE_VND=13000
BUDGET_TRANSPORT_BIKE_PER_KM_VND=4300
BUDGET_TRANSPORT_CAR_BASE_VND=20000
BUDGET_TRANSPORT_CAR_PER_KM_VND=12000
BUDGET_TRANSPORT_ROAD_FACTOR=1.3
# Tỷ giá quy đổi vé bay (Ignav trả USD) — cập nhật tay khi biến động mạnh
USD_VND_RATE=26500

# Makcorps (script test.js)
MAKCORPS_API_KEY=your_makcorps_api_key
